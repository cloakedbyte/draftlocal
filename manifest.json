{
  "manifest_version": 3,
  "name": "DraftLocal",
  "version": "0.0.1",
  "description": "DraftLocal — a minimal offline-only note-taking extension. No sync, no accounts, no network requests.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
